# ResKiosk Environment Configuration
# Copy this file to .env and customize the values as needed

# =============================================================================
# DATABASE & STORAGE
# =============================================================================

# Path to the SQLite database file
# If not set, defaults to platform-specific location:
# - Windows: %APPDATA%/ResKiosk/reskiosk.db
# - Linux/Mac: ~/.local/share/reskiosk/reskiosk.db
# RESKIOSK_DB_PATH=/path/to/custom/reskiosk.db

# Project root directory (for development/testing)
# RESKIOSK_PROJECT_ROOT=/path/to/project

# =============================================================================
# AI MODELS & LLM CONFIGURATION
# =============================================================================

# Ollama server URL
OLLAMA_URL=http://localhost:11434

# Primary LLM model (fallback for formatter and rewriter if specific models not set)
RESKIOSK_LLM_MODEL=translategemma:4b

# Formatter model (for response formatting)
RESKIOSK_FORMAT_MODEL=translategemma:4b

# Query rewriter model (for query enhancement)
RESKIOSK_REWRITE_MODEL=llama3.2:3b

# Enable query rewriting (true/false)
RESKIOSK_QUERY_REWRITE=false

# Path to local AI models directory
# RESKIOSK_MODELS_PATH=/path/to/models

# Path to NLLB translation model
# RESKIOSK_NLLB_PATH=/path/to/nllb/model

# =============================================================================
# SEARCH & RETRIEVAL SETTINGS
# =============================================================================

# Similarity threshold for search results (0.0-1.0)
RESKIOSK_SIM_THRESHOLD=0.60

# Threshold below which clarification is triggered
RESKIOSK_CLARIFICATION_FLOOR=0.40

# Similarity thresholds for non-English queries
RESKIOSK_NON_EN_SIM_THRESHOLD=0.50
RESKIOSK_NON_EN_CLARIFICATION_FLOOR=0.38

# =============================================================================
# RLHF (Reinforcement Learning from Human Feedback)
# =============================================================================

# Enable RLHF bias learning (true/false)
RESKIOSK_RLHF_ENABLED=false

# RLHF learning rate (0.0-1.0)
RESKIOSK_RLHF_ALPHA=0.10

# Minimum events before RLHF takes effect
RESKIOSK_RLHF_MIN_EVENTS=3

# RLHF decay factor for bias updates
RESKIOSK_RLHF_DECAY=0.9

# Time-to-live for RLHF bias cache (seconds)
RESKIOSK_RLHF_BIAS_TTL_SECS=1800

# Directory for RLHF lock files
# RESKIOSK_RLHF_LOCK_DIR=/path/to/lock/dir

# =============================================================================
# CLOUD SERVICES (Currently Disabled)
# =============================================================================

# Enable cloud services (true/false) - Currently paused
RESKIOSK_CLOUD_ENABLED=false

# OpenAI API key for cloud services
# OPENAI_API_KEY=your_openai_api_key_here

# Cloud Speech-to-Text Configuration
RESKIOSK_CLOUD_STT_MODEL=whisper-1
RESKIOSK_CLOUD_STT_TIMEOUT_SECS=3.0
RESKIOSK_OPENAI_STT_URL=https://api.openai.com/v1/audio/transcriptions

# Cloud Text-to-Speech Configuration  
RESKIOSK_CLOUD_TTS_MODEL=tts-1
RESKIOSK_CLOUD_TTS_VOICE=nova
RESKIOSK_CLOUD_TTS_TIMEOUT_SECS=3.0
RESKIOSK_OPENAI_TTS_URL=https://api.openai.com/v1/audio/speech

# Cloud Formatting Configuration
RESKIOSK_CLOUD_FORMAT_MODEL=gpt-4o-mini
RESKIOSK_CLOUD_FORMAT_TIMEOUT_SECS=2.0
RESKIOSK_OPENAI_CHAT_URL=https://api.openai.com/v1/chat/completions

# =============================================================================
# LORA ENCRYPTION
# =============================================================================

# AES-256-GCM encryption key for hub-to-hub LoRa messages (64 hex characters)
# If not set, messages are sent in plaintext for backward compatibility
# All hubs in the network must share the same key
# Generate a new key via the admin console or use: python -c "import os; print(os.urandom(32).hex())"
LORA_ENCRYPTION_KEY=e37d8df18ebed3ddc90806497121089dca85d91d35e586f442a084691bcde124

# =============================================================================
# CONNECTIVITY & MONITORING
# =============================================================================

# Connectivity check interval (seconds)
RESKIOSK_CONNECTIVITY_POLL_SECS=30

# Online threshold for connectivity checks (milliseconds)
RESKIOSK_CONNECTIVITY_ONLINE_MS=1000

# Timeout for connectivity probes (seconds)
RESKIOSK_CONNECTIVITY_TIMEOUT_SECS=3.0

# Target URL for connectivity checks
RESKIOSK_CONNECTIVITY_TARGET=https://api.openai.com

# =============================================================================
# DEVELOPMENT & DEBUGGING
# =============================================================================

# Enable debug logging
# DEBUG=true

# Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# =============================================================================
# NOTES
# =============================================================================

# 1. This file should not be committed to version control if it contains secrets
# 2. Copy this file to .env and customize values as needed
# 3. Boolean values: use "true"/"false", "1"/"0", "yes"/"no", or "on"/"off"
# 4. Paths can be absolute or relative to the project root
# 5. Cloud services are currently disabled in the codebase
# 6. The system is designed to work fully offline-first